#!/usr/bin/env python3
import json
import subprocess
import sys


def run(cmd):
    subprocess.run(cmd, shell=True, check=False)


def main():
    try:
        first_line = sys.stdin.readline()
        data = json.loads(first_line)
    except Exception:
        sys.exit(1)

    command = data.get("command", "")
    alert   = data.get("parameters", {}).get("alert", {})
    srcip   = alert.get("data", {}).get("srcip", "")

    if not srcip:
        keys  = data.get("parameters", {}).get("keys", [])
        srcip = keys[0] if keys else ""

    if not srcip:
        sys.exit(1)

    if command == "add":
        check_keys = json.dumps({
            "version": 1,
            "origin": {"name": "firewall-block-persistent", "module": "active-response"},
            "command": "check_keys",
            "parameters": {"keys": [srcip]}
        })
        print(check_keys, flush=True)

        try:
            cont_line = sys.stdin.readline()
            cont_data = json.loads(cont_line)
            if cont_data.get("command") != "continue":
                sys.exit(0)
        except Exception:
            sys.exit(0)

        run(f"iptables -C INPUT -s {srcip} -j DROP 2>/dev/null || iptables -I INPUT -s {srcip} -j DROP")
        run("iptables-save > /etc/iptables/rules.v4")

    elif command == "delete":
        run(f"iptables -D INPUT -s {srcip} -j DROP 2>/dev/null")
        run("iptables-save > /etc/iptables/rules.v4")


if __name__ == "__main__":
    main()
